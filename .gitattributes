# 자동 라인 엔딩 정규화 (텍스트 파일 자동 감지)
* text=auto

# 셸 스크립트는 무조건 LF (Linux/macOS 에서 깨지지 않도록)
*.sh text eol=lf

# Python / 설정 파일은 LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# 윈도우 배치 파일은 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리는 변환 금지
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
