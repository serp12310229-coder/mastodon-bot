# ============================================================
# CoC 봇 설정 파일
# ============================================================
# 사용법: cp .env.example .env  후 아래 값을 채우세요.
# 보통은 install.sh 가 자동 생성하므로 직접 만들 일은 없습니다.

# ------------------------------------------------------------
# 마스토돈 (필수)
# ------------------------------------------------------------

# 봇이 접속할 마스토돈 서버 주소 (https:// 포함)
MASTODON_API_BASE_URL=https://example.xyz

# 봇 계정의 액세스 토큰
MASTODON_ACCESS_TOKEN=

# 한 툿당 글자수 제한 (서버 설정과 동일하게)
MAX_MESSAGE_LENGTH=1000

# ------------------------------------------------------------
# Google Sheets (메인 시트 하나)
# ------------------------------------------------------------
# 서비스 계정 이메일이 메인 시트에 '편집자' 로 공유되어 있어야 합니다.

# 서비스 계정 키 파일 경로 (기본값: 프로젝트 루트의 credentials.json)
GOOGLE_CREDENTIALS_PATH=credentials.json

# 메인 시트 — 도움말 / 커스텀 / 장비 및 주식 / 레이드 정보 / 전투용 정보 /
#             상점 / 자동봇용 정보 페이지를 모두 포함.
SHEET_ID=

# (선택) '커스텀' 워크시트 이름이 다르면 여기서 오버라이드.
# CUSTOM_COMMAND_WORKSHEET=커스텀

# (선택) '도움말' 워크시트 이름이 다르면 여기서 오버라이드.
# HELP_SHEET=도움말

# ------------------------------------------------------------
# 알림 / 가동 기간 (선택)
# ------------------------------------------------------------

# 오류 알림 받을 KPC/GM 계정 (@ 없이, 콤마로 여러 명 가능)
SYSTEM_ADMIN_ID=

# 가동 시작일 (KST 기준 YYYY-MM-DD, 비우면 즉시 시작)
OPERATION_START_DATE=

# 가동 종료일 (KST 기준 YYYY-MM-DD, 비우면 무기한)
# 종료일 00:00 부터 사용자당 1회 만료 안내 후 침묵.
OPERATION_END_DATE=

# ------------------------------------------------------------
# 출력 스타일
# ------------------------------------------------------------

# 서버가 Markdown(*기울임*/**볼드**) 을 렌더링하는지 여부.
# true  → 기능명/판정결과/피해 값을 **볼드** 로 감싸 출력 (한참 등 일부 인스턴스)
# false → 평문 출력 (마스토돈 본가 포함 대부분의 서버)
MARKDOWN_ENABLED=false

# 판정 출력 시 제목 라인에 붙는 장식 특수문자.
#   기본값(✦)  → DECORATION_CHAR=✦
#   다른 문자  → DECORATION_CHAR=★    (✧, 💎, ◆ 등 자유롭게)
#   장식 생략  → DECORATION_CHAR=     (값을 비우면 제목에 아무 것도 안 붙음)
DECORATION_CHAR=✦

# 장식 문자를 제목 양옆에 붙일지(true) 앞에만 붙일지(false).
#   true  → ✦ 관찰력 ✦
#   false → ✦ 관찰력
DECORATION_BOTH_SIDES=true
